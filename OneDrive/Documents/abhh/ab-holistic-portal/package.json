{
  "name": "ab-holistic-portal",
  "version": "1.0.0",
  "description": "AB Holistic Interview Portal - Secure cloud-native recruitment platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "test:integration": "npm run test:integration:frontend && npm run test:integration:backend",
    "test:integration:frontend": "cd frontend && npm run test:integration",
    "test:integration:backend": "cd backend && npm run test:integration",
    "test:e2e": "cd tests/e2e && npm test",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "cd frontend && npm run typecheck",
    "typecheck:backend": "cd backend && npm run typecheck",
    "deploy:dev": "npm run deploy:backend:dev && npm run deploy:frontend:dev",
    "deploy:staging": "npm run deploy:backend:staging && npm run deploy:frontend:staging",
    "deploy:prod": "npm run deploy:backend:prod && npm run deploy:frontend:prod",
    "deploy:frontend:dev": "cd frontend && npm run deploy:dev",
    "deploy:frontend:staging": "cd frontend && npm run deploy:staging",
    "deploy:frontend:prod": "cd frontend && npm run deploy:prod",
    "deploy:backend:dev": "cd backend && npm run deploy:dev",
    "deploy:backend:staging": "cd backend && npm run deploy:staging",
    "deploy:backend:prod": "cd backend && npm run deploy:prod",
    "clean": "npm run clean:frontend && npm run clean:backend",
    "clean:frontend": "cd frontend && npm run clean",
    "clean:backend": "cd backend && npm run clean",
    "setup": "npm install && npm run setup:frontend && npm run setup:backend",
    "setup:frontend": "cd frontend && npm install",
    "setup:backend": "cd backend && npm install"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "interview-portal",
    "recruitment",
    "aws",
    "serverless",
    "react",
    "typescript",
    "amplify"
  ],
  "author": "AB Holistic Health",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
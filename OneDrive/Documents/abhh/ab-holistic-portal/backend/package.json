{
  "name": "ab-holistic-backend",
  "version": "1.0.0",
  "description": "Backend Lambda functions for AB Holistic Interview Portal",
  "main": "index.js",
  "scripts": {
    "dev": "serverless offline",
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:staging": "serverless deploy --stage staging",
    "deploy:prod": "serverless deploy --stage prod",
    "logs": "serverless logs -f",
    "remove": "serverless remove",
    "clean": "rimraf dist .serverless"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.450.0",
    "@aws-sdk/client-dynamodb": "^3.888.0",
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/client-ses": "^3.450.0",
    "@aws-sdk/client-sns": "^3.450.0",
    "@aws-sdk/lib-dynamodb": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "aws-lambda": "^1.0.7",
    "bcryptjs": "^2.4.3",
    "date-fns": "^2.30.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.126",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.19.15",
    "@types/uuid": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.5",
    "serverless": "^3.40.0",
    "serverless-offline": "^13.3.0",
    "serverless-plugin-typescript": "^2.1.5",
    "serverless-webpack": "^5.13.0",
    "serverless-plugin-warmup": "^8.2.2",
    "serverless-plugin-canary-deployments": "^0.7.0",
    "serverless-plugin-aws-alerts": "^1.8.0",
    "serverless-prune-plugin": "^2.1.0",
    "serverless-domain-manager": "^7.3.6",
    "serverless-plugin-split-stacks": "^1.11.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.9.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "keywords": [
    "aws",
    "lambda",
    "serverless",
    "interview-portal",
    "typescript"
  ],
  "author": "AB Holistic Health",
  "license": "UNLICENSED"
}

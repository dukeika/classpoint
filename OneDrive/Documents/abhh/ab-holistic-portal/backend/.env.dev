# Development Environment Configuration
STAGE=dev
REGION=us-west-1
NODE_ENV=development

# Cognito Configuration
COGNITO_USER_POOL_ID=us-west-1_n0Ij4uUuB
COGNITO_USER_POOL_WEB_CLIENT_ID=742a4q83obkfejdod7d1retvep
COGNITO_USER_POOL_DOMAIN=ab-holistic-portal-dev
COGNITO_HOSTED_UI_URL=https://ab-holistic-portal-dev.auth.us-west-1.amazoncognito.com
JWT_SECRET=dev-jwt-secret-ab-holistic-2024
VERIFY_WITH_COGNITO=true

# DynamoDB Tables
JOBS_TABLE=ab-holistic-interview-portal-jobs-dev
APPLICANTS_TABLE=ab-holistic-interview-portal-applicants-dev
APPLICATIONS_TABLE=ab-holistic-interview-portal-applications-dev
TESTS_TABLE=ab-holistic-interview-portal-tests-dev
TEST_SUBMISSIONS_TABLE=ab-holistic-interview-portal-test-submissions-dev
NOTIFICATIONS_TABLE=ab-holistic-interview-portal-notifications-dev

# S3 Buckets
S3_BUCKET_RESUMES=ab-holistic-interview-portal-resumes-dev
S3_BUCKET_VIDEOS=ab-holistic-interview-portal-videos-dev

# API Configuration
API_ENDPOINT=https://04efp4qnv4.execute-api.us-west-1.amazonaws.com/dev
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://localhost:3000

# Email Configuration
SES_FROM_EMAIL=dev-noreply@abholisticportal.com
SES_REGION=us-west-1

# Monitoring and Logging
LOG_LEVEL=debug
ENABLE_X_RAY=false
CLOUDWATCH_LOG_GROUP=/aws/lambda/ab-holistic-interview-portal-dev

# Security Configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=100
SESSION_TIMEOUT_MINUTES=30

# DynamoDB Configuration
DYNAMODB_BILLING_MODE=PAY_PER_REQUEST
DYNAMODB_AUTO_SCALING=false

# Performance Configuration
ENABLE_WARMUP=false

# Development-specific Configuration
ENABLE_DEBUG_LOGS=true
MOCK_EMAIL_DELIVERY=true
BYPASS_RATE_LIMITING=false

# Monitoring Configuration
ALERT_EMAIL=dev-alerts@abholisticportal.com